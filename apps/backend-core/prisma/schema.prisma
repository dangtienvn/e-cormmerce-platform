// ==========================================
// PRISMA SCHEMA DEFINITION
// File định nghĩa cấu trúc cơ sở dữ liệu (Database Schema) cho hệ thống CRM.
// Các model trong này sẽ được map với các bảng trong PostgreSQL.
// ==========================================

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Bảng lưu trữ nhật ký hoạt động (Activity Logs) của hệ thống.
model activity_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  action      String?   @db.VarChar(100)
  entity_type String?   @db.VarChar(50)
  entity_id   Int?
  description String?   @db.Text
  old_data    Json?
  new_data    Json?
  created_at  DateTime? @default(now()) @db.Timestamp(3)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
}

/// Bảng danh mục sản phẩm.
model categories {
  id         Int        @id @default(autoincrement())
  name       String?    @unique @db.VarChar(100)
  deleted_at DateTime?  @db.Timestamp(3)
  created_at DateTime?  @default(now()) @db.Timestamp(3)
  products   products[]
}

/// Bảng lưu trữ thông tin/hồ sơ mở rộng của khách hàng.
model customer_profiles {
  id            Int       @id @default(autoincrement())
  user_id       Int?      @unique
  source        String?   @default("manual") @db.VarChar(100)
  status        String?   @default("lead") @db.VarChar(50)
  note          String?   @db.Text
  total_spent   Decimal?  @default(0.00) @db.Decimal(10, 2)
  total_orders  Int?      @default(0)
  last_order_at DateTime? @db.Timestamp(3)
  created_at    DateTime? @default(now()) @db.Timestamp(3)
  updated_at    DateTime? @db.Timestamp(3)
  tag           String?   @default("Normal") @db.VarChar(50)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id])
}

/// Bảng theo dõi lịch sử tải xuống các sản phẩm kỹ thuật số của người dùng.
model downloads {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  product_id    Int?
  order_id      Int?
  ip_address    String?   @db.VarChar(45)
  user_agent    String?   @db.Text
  downloaded_at DateTime? @default(now()) @db.Timestamp(3)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products      products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders        orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id])
  @@index([product_id])
  @@index([user_id])
}

/// Bảng ghi nhận chi phí, vận hành hoặc chi phí quảng cáo cho từng sản phẩm.
model expenses {
  id         Int            @id @default(autoincrement())
  name       String?        @db.VarChar(100)
  amount     Decimal?       @db.Decimal(10, 2)
  type       expenses_type?
  note       String?        @db.Text
  created_at DateTime?      @default(now()) @db.Timestamp(3)
  product_id Int?
  deleted_at DateTime?      @db.Timestamp(3)
  products   products?      @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([product_id])
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  message    String    @db.VarChar(255)
  link       String?   @db.VarChar(255)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(3)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model order_items {
  id           Int       @id @default(autoincrement())
  order_id     Int?
  product_id   Int?
  product_name String?   @db.VarChar(150)
  price        Decimal?  @db.Decimal(10, 2)
  cost_price   Decimal?  @db.Decimal(10, 2)
  quantity     Int?      @default(1)
  total_price  Decimal?  @db.Decimal(10, 2)
  orders       orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products     products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id])
  @@index([product_id])
}

/// Bảng lưu trữ thông tin các đơn hàng.
model orders {
  id                              Int              @id @default(autoincrement())
  customer_id                     Int?
  billing_name                    String?          @db.VarChar(255)
  billing_email                   String?          @db.VarChar(255)
  billing_phone                   String?          @db.VarChar(50)
  total_amount                    Decimal?         @default(0.00) @db.Decimal(10, 2)
  discount                        Decimal?         @default(0.00) @db.Decimal(10, 2)
  final_amount                    Decimal?         @default(0.00) @db.Decimal(10, 2)
  status                          orders_status?   @default(pending)
  created_by                      Int?
  deleted_at                      DateTime?        @db.Timestamp(3)
  created_at                      DateTime?        @default(now()) @db.Timestamp(3)
  updated_at                      DateTime?        @db.Timestamp(3)
  payment_method                  String?          @default("") @db.VarChar(50)
  payment_status                  payments_status? @default(pending)
  currency                        String?          @default("VND") @db.VarChar(10)
  voucher_code                    String?          @db.VarChar(50)
  downloads                       downloads[]
  order_items                     order_items[]
  users_orders_customer_idTousers users?           @relation("orders_customer_idTousers", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_orders_created_byTousers  users?           @relation("orders_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  owned_products                  owned_products[]
  payments                        payments[]
  reviews                         reviews[]

  @@index([created_by])
  @@index([status])
  @@index([customer_id])
}

model owned_products {
  id                Int       @id @default(autoincrement())
  user_id           Int?
  product_id        Int?
  order_id          Int?
  access_expires_at DateTime? @db.Timestamp(3)
  download_limit    Int?
  status            String?   @default("active") @db.VarChar(50)
  created_at        DateTime? @default(now()) @db.Timestamp(3)
  deleted_at        DateTime? @db.Timestamp(3)
  users             users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products          products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders            orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, product_id])
  @@index([product_id])
  @@index([user_id])
  @@index([order_id])
}

model permission {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)
}

model password_resets {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamp(3)
  created_at DateTime? @default(now()) @db.Timestamp(3)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model payments {
  id               Int              @id @default(autoincrement())
  order_id         Int?
  amount           Decimal?         @db.Decimal(10, 2)
  status           payments_status? @default(pending)
  payment_method   String?          @db.VarChar(50)
  transaction_code String?          @db.VarChar(100)
  paid_at          DateTime?        @db.Timestamp(3)
  created_at       DateTime?        @default(now()) @db.Timestamp(3)
  orders           orders?          @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id, status])
}

model product_images {
  id         Int       @id @default(autoincrement())
  product_id Int?
  image_url  String?   @db.Text
  is_primary Boolean?  @default(false)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id])
}

/// Bảng lưu trữ thông tin cốt lõi của sản phẩm.
model products {
  id                                Int              @id @default(autoincrement())
  sku                               String?          @unique @db.VarChar(50)
  name                              String?          @db.VarChar(150)
  description                       String?          @db.Text
  price                             Decimal          @db.Decimal(10, 2)
  cost_price                        Decimal?         @default(0.00) @db.Decimal(10, 2)
  original_cost                     Decimal?         @default(0.00) @db.Decimal(10, 2)
  cost_details                      String?          @db.Text
  category_id                       Int?
  type                              products_type?   @default(ebook)
  download_url                      String?          @db.VarChar(255)
  version                           String?          @default("1.0.0") @db.VarChar(20)
  file_size                         Int? // size in bytes
  status                            products_status? @default(draft)
  is_active                         Boolean?         @default(true)
  created_by                        Int?
  approved_by                       Int?
  approved_at                       DateTime?        @db.Timestamp(3)
  feedback                          String?          @db.Text
  deleted_at                        DateTime?        @db.Timestamp(3)
  created_at                        DateTime?        @default(now()) @db.Timestamp(3)
  updated_at                        DateTime?        @db.Timestamp(3)
  cart_items                        cart_items[]
  downloads                         downloads[]
  expenses                          expenses[]
  order_items                       order_items[]
  owned_products                    owned_products[]
  product_images                    product_images[]
  categories                        categories?      @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_products_created_byTousers  users?           @relation("products_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_products_approved_byTousers users?           @relation("products_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews                           reviews[]

  @@index([approved_by])
  @@index([created_by])
  @@index([is_active])
  @@index([category_id])
  @@index([status])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  product_id Int?
  order_id   Int?
  rating     Int?
  comment    String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(3)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products   products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders     orders?   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, product_id])
  @@index([order_id])
  @@index([product_id])
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  users            users[]
  role_permissions role_permissions[]
}

model permissions {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(100)
  description      String?            @db.Text
  module           String?            @db.VarChar(50)
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

model support_tickets {
  id          Int                     @id @default(autoincrement())
  user_id     Int
  subject     String                  @db.VarChar(255)
  message     String                  @db.Text
  status      support_tickets_status? @default(open)
  admin_reply String?                 @db.Text
  created_at  DateTime?               @default(now()) @db.Timestamp(3)
  updated_at  DateTime?               @default(now()) @db.Timestamp(3)
  users       users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

/// Bảng lưu trữ thông tin tài khoản người dùng (Admin, Khách hàng).
model users {
  id                                   Int                @id @default(autoincrement())
  username                             String?            @db.VarChar(100)
  email                                String             @unique @db.VarChar(100)
  password                             String             @db.VarChar(255)
  full_name                            String?            @db.VarChar(100)
  phone                                String?            @unique @db.VarChar(20)
  role_id                              Int
  is_locked                            Boolean?           @default(false)
  email_verified_at                    DateTime?          @db.Timestamp(3)
  deleted_at                           DateTime?          @db.Timestamp(3)
  created_at                           DateTime?          @default(now()) @db.Timestamp(3)
  updated_at                           DateTime?          @db.Timestamp(3)
  address                              String?            @db.VarChar(255)
  note                                 String?            @db.Text
  interactions                         Int?               @default(0)
  source                               String?            @default("manual") @db.VarChar(100)
  status                               String?            @default("lead") @db.VarChar(50)
  tag                                  String?            @default("Normal") @db.VarChar(50)
  avatar_url                           String?            @db.Text
  activity_logs                        activity_logs[]
  cart_items                           cart_items[]
  login_attempts                       login_attempts[]
  customer_profiles                    customer_profiles?
  downloads                            downloads[]
  notifications                        notifications[]
  orders_orders_customer_idTousers     orders[]           @relation("orders_customer_idTousers")
  orders_orders_created_byTousers      orders[]           @relation("orders_created_byTousers")
  owned_products                       owned_products[]
  password_resets                      password_resets[]
  products_products_created_byTousers  products[]         @relation("products_created_byTousers")
  products_products_approved_byTousers products[]         @relation("products_approved_byTousers")
  reviews                              reviews[]
  support_tickets                      support_tickets[]
  roles                                roles              @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  posts                                posts[]

  @@index([email])
  @@index([role_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vouchers {
  id                  Int       @id @default(autoincrement())
  code                String    @unique @db.VarChar(50)
  discount_percent    Decimal   @db.Decimal(5, 2)
  max_uses            Int?      @default(0)
  used_count          Int?      @default(0)
  min_order_value     Decimal?  @default(0.00) @db.Decimal(10, 2)
  max_discount_amount Decimal?  @db.Decimal(10, 2)
  usage_per_user      Int?      @default(1)
  expiry_date         DateTime? @db.Timestamp(3)
  is_active           Boolean?  @default(true)
  created_at          DateTime? @default(now()) @db.Timestamp(3)
  deleted_at          DateTime? @db.Timestamp(3)
}

enum expenses_type {
  ads
  operation
  other
}

enum payments_status {
  pending
  success
  failed
}

enum support_tickets_status {
  open
  resolved
}

enum orders_status {
  pending
  paid
  revoked
}

enum products_type {
  ebook
  course
  template
  plugin
}

enum products_status {
  draft
  pending_review
  published
  rejected
  inactive
}

model login_attempts {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  ip_address String?   @db.VarChar(45)
  user_agent String?   @db.Text
  success    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(3)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
}

model cart_items {
  id         Int       @id @default(autoincrement())
  user_id    Int
  product_id Int
  created_at DateTime? @default(now()) @db.Timestamp(3)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@index([product_id])
}

model post_categories {
  id         Int               @id @default(autoincrement())
  name       String            @db.VarChar(100)
  slug       String            @unique @db.VarChar(100)
  parent_id  Int?
  parent     post_categories?  @relation("PostCategoryToPostCategory", fields: [parent_id], references: [id])
  children   post_categories[] @relation("PostCategoryToPostCategory")
  posts      posts[]
  position   Int               @default(0)
  created_at DateTime          @default(now()) @db.Timestamp(3)
  updated_at DateTime          @updatedAt @db.Timestamp(3)
}

model posts {
  id                 Int              @id @default(autoincrement())
  title              String           @db.VarChar(255)
  slug               String           @unique @db.VarChar(255)
  content            String           @db.Text
  thumbnail          String?          @db.Text
  external_store_url String?          @db.Text
  status             post_status      @default(DRAFT)
  author_id          Int
  author             users            @relation(fields: [author_id], references: [id])
  category_id        Int?
  category           post_categories? @relation(fields: [category_id], references: [id])
  created_at         DateTime         @default(now()) @db.Timestamp(3)
  updated_at         DateTime         @updatedAt @db.Timestamp(3)

  @@index([author_id])
  @@index([category_id])
  @@index([status])
}

enum post_status {
  DRAFT
  PUBLISHED
}
